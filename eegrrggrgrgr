<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vélo O CMC – La liberté, c'est sur deux roues !</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Rajdhani:wght@400;600;700&family=Open+Sans:ital,wght@0,400;0,600;1,400&display=swap" rel="stylesheet">
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

:root {
  --green-dark: #1a5c2e;
  --green-mid: #1e6e35;
  --green-light: #2d8a45;
  --orange: #e07b00;
  --orange-light: #f59520;
  --yellow: #f5c842;
  --white: #ffffff;
  --text-light: #c8e0bc;
  --text-muted: #7db87a;
}

html { scroll-behavior: smooth; }

body {
  font-family: 'Open Sans', sans-serif;
  background: var(--green-dark);
  color: var(--white);
  overflow-x: hidden;
}

/* ─── TYPOGRAPHY ─── */
h1, h2, h3, h4, .nav-link, .btn {
  font-family: 'Rajdhani', sans-serif;
}

/* ─── NAV ─── */
.nav {
  background: var(--white);
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 2.5rem;
  height: 56px;
  border-bottom: 3px solid var(--orange);
  position: sticky;
  top: 0;
  z-index: 100;
}

.logo {
  display: flex;
  align-items: center;
  gap: 10px;
  text-decoration: none;
}

.logo-icon {
  width: 40px; height: 40px;
  background: var(--green-dark);
  border-radius: 6px;
  display: flex; align-items: center; justify-content: center;
}

.logo-text {
  font-family: 'Rajdhani', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--green-dark);
  line-height: 1.1;
  text-transform: uppercase;
}

.logo-text span { color: var(--orange); }

.nav-links {
  display: flex;
  gap: 1.8rem;
  list-style: none;
}

.nav-link {
  font-size: 13px;
  font-weight: 700;
  text-decoration: none;
  color: #1a1a1a;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  padding-bottom: 3px;
  transition: color 0.2s;
}

.nav-link:hover, .nav-link.active {
  color: var(--orange);
  border-bottom: 2px solid var(--orange);
}

/* ─── HERO ─── */
.hero {
  position: relative;
  min-height: 480px;
  background:
    linear-gradient(rgba(5,25,10,0.60) 0%, rgba(5,25,10,0.25) 60%, rgba(5,25,10,0.55) 100%),
    url('https://images.unsplash.com/photo-1544191696-102dbdaeeaa0?w=1200&q=80') center/cover no-repeat;
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 3rem 3rem 5rem;
}

.hero-title {
  font-size: 2.8rem;
  font-weight: 700;
  color: var(--yellow);
  text-transform: uppercase;
  letter-spacing: 0.03em;
  line-height: 1.1;
  max-width: 520px;
  margin-bottom: 1.2rem;
  text-shadow: 0 2px 12px rgba(0,0,0,0.5);
}

.hero-sub {
  font-size: 14px;
  color: #ddefd8;
  max-width: 380px;
  line-height: 1.7;
  margin-bottom: 1.8rem;
}

.btn {
  display: inline-block;
  background: var(--orange);
  color: var(--white);
  font-family: 'Rajdhani', sans-serif;
  font-weight: 700;
  font-size: 13px;
  text-transform: uppercase;
  letter-spacing: 0.07em;
  padding: 10px 28px;
  border-radius: 4px;
  text-decoration: none;
  border: none;
  cursor: pointer;
  transition: background 0.2s, transform 0.15s;
}

.btn:hover { background: var(--orange-light); transform: translateY(-1px); }

.btn-outline {
  background: transparent;
  border: 2px solid var(--yellow);
  color: var(--yellow);
}
.btn-outline:hover { background: var(--yellow); color: var(--green-dark); }

/* ─── SEARCH BAR ─── */
.search-row {
  position: absolute;
  bottom: -22px;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 10px;
  align-items: center;
  background: rgba(10,40,15,0.7);
  padding: 12px 18px;
  border-radius: 6px;
  backdrop-filter: blur(4px);
  white-space: nowrap;
}

.search-input, .search-select {
  background: rgba(255,255,255,0.92);
  border: 1.5px solid rgba(255,255,255,0.4);
  border-radius: 4px;
  padding: 8px 14px;
  font-size: 12px;
  font-family: 'Open Sans', sans-serif;
  color: #333;
  cursor: pointer;
  min-width: 120px;
}

.search-select { appearance: none; }

/* ─── SECTION CHEVRON ─── */
.chevron-orange {
  height: 60px;
  background: var(--orange);
  clip-path: polygon(0 0, 100% 0, 50% 100%);
  margin-top: 30px;
}

.chevron-green {
  height: 60px;
  background: var(--green-dark);
  clip-path: polygon(0 0, 100% 0, 50% 100%);
}

/* ─── SECTION BASE ─── */
.section {
  padding: 4rem 3rem;
}

.section-title {
  font-size: 2rem;
  font-weight: 700;
  color: var(--yellow);
  text-align: center;
  margin-bottom: 2.5rem;
  letter-spacing: 0.02em;
}

/* ─── BIKES SECTION ─── */
.bikes-section { background: var(--green-dark); }

.bikes-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2.5rem 3rem;
  max-width: 800px;
  margin: 0 auto;
}

.bike-card { display: flex; flex-direction: column; }

.diamond-wrap {
  width: 120px;
  height: 120px;
  margin-bottom: 0.9rem;
}

.bike-name {
  font-family: 'Rajdhani', sans-serif;
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 0.4rem;
  letter-spacing: 0.02em;
}

.bike-desc {
  font-size: 12.5px;
  color: var(--text-light);
  line-height: 1.6;
}

/* ─── CIRCUITS SECTION ─── */
.circuits-section { background: var(--green-mid); }

.circuits-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  max-width: 900px;
  margin: 0 auto;
}

.circuit-card {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.15);
  border-radius: 8px;
  overflow: hidden;
  transition: transform 0.2s, box-shadow 0.2s;
}

.circuit-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0,0,0,0.3);
}

.circuit-img {
  width: 100%;
  height: 140px;
  object-fit: cover;
  display: block;
  background: #2a7040;
}

.circuit-img-placeholder {
  width: 100%;
  height: 140px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
}

.circuit-body { padding: 1rem 1.2rem 1.4rem; }

.circuit-badge {
  display: inline-block;
  font-family: 'Rajdhani', sans-serif;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  padding: 3px 10px;
  border-radius: 3px;
  margin-bottom: 0.6rem;
}

.badge-easy { background: #2ecc71; color: #0a3a1a; }
.badge-medium { background: var(--orange); color: #3a1800; }
.badge-hard { background: #c0392b; color: #fff; }

.circuit-name {
  font-family: 'Rajdhani', sans-serif;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 0.3rem;
}

.circuit-meta {
  display: flex;
  gap: 1rem;
  margin-bottom: 0.7rem;
}

.circuit-meta span {
  font-size: 12px;
  color: var(--text-muted);
  display: flex;
  align-items: center;
  gap: 4px;
}

.circuit-desc {
  font-size: 12px;
  color: var(--text-light);
  line-height: 1.55;
}

/* ─── HISTOIRE SECTION ─── */
.histoire-section {
  background: var(--orange);
  padding: 4rem 3rem;
}

.histoire-inner {
  max-width: 900px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
  align-items: center;
}

.histoire-section .section-title {
  color: var(--white);
  text-align: left;
  margin-bottom: 1.2rem;
}

.histoire-text {
  font-size: 14px;
  color: rgba(255,255,255,0.9);
  line-height: 1.8;
  margin-bottom: 1.4rem;
}

.histoire-img-block {
  position: relative;
}

.histoire-img-placeholder {
  width: 100%;
  aspect-ratio: 4/3;
  background: rgba(0,0,0,0.2);
  border-radius: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 4rem;
}

.histoire-stat {
  position: absolute;
  bottom: -16px;
  right: -16px;
  background: var(--green-dark);
  color: var(--yellow);
  border-radius: 6px;
  padding: 12px 18px;
  text-align: center;
}

.histoire-stat-num {
  font-family: 'Rajdhani', sans-serif;
  font-size: 2rem;
  font-weight: 700;
  display: block;
}

.histoire-stat-label {
  font-size: 11px;
  color: var(--text-light);
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

/* ─── TEMOIGNAGES ─── */
.temoignages-section { background: var(--green-dark); }

.temoignages-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  max-width: 900px;
  margin: 0 auto;
}

.temoignage-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 8px;
  padding: 1.4rem;
}

.stars { color: var(--yellow); font-size: 14px; margin-bottom: 0.7rem; letter-spacing: 2px; }

.temoignage-text {
  font-size: 13px;
  color: var(--text-light);
  line-height: 1.65;
  font-style: italic;
  margin-bottom: 1rem;
}

.temoignage-author {
  display: flex;
  align-items: center;
  gap: 10px;
}

.author-avatar {
  width: 36px; height: 36px;
  border-radius: 50%;
  background: var(--green-light);
  display: flex; align-items: center; justify-content: center;
  font-family: 'Rajdhani', sans-serif;
  font-weight: 700;
  font-size: 13px;
  color: var(--white);
  flex-shrink: 0;
}

.author-name {
  font-family: 'Rajdhani', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--white);
}

.author-date {
  font-size: 11px;
  color: var(--text-muted);
}

/* ─── FAQ ─── */
.faq-section { background: var(--green-mid); }

.faq-list {
  max-width: 700px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.faq-item {
  background: rgba(255,255,255,0.07);
  border: 1px solid rgba(255,255,255,0.13);
  border-radius: 6px;
  overflow: hidden;
}

.faq-question {
  width: 100%;
  background: none;
  border: none;
  color: var(--white);
  font-family: 'Rajdhani', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  letter-spacing: 0.03em;
  text-align: left;
  padding: 1rem 1.3rem;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.faq-question:hover { color: var(--yellow); }

.faq-arrow {
  font-size: 1.2rem;
  transition: transform 0.3s;
  color: var(--orange);
}

.faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.35s ease, padding 0.2s;
  font-size: 13px;
  color: var(--text-light);
  line-height: 1.7;
  padding: 0 1.3rem;
}

.faq-item.open .faq-arrow { transform: rotate(180deg); }
.faq-item.open .faq-answer { max-height: 200px; padding: 0 1.3rem 1rem; }

/* ─── BLOG ─── */
.blog-section { background: var(--green-dark); }

.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.5rem;
  max-width: 900px;
  margin: 0 auto 2rem;
}

.blog-card {
  background: rgba(255,255,255,0.06);
  border: 1px solid rgba(255,255,255,0.12);
  border-radius: 8px;
  overflow: hidden;
  transition: transform 0.2s;
}

.blog-card:hover { transform: translateY(-3px); }

.blog-thumb {
  width: 100%;
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2.5rem;
}

.blog-body { padding: 1rem 1.1rem 1.3rem; }

.blog-tag {
  font-family: 'Rajdhani', sans-serif;
  font-size: 11px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--orange);
  margin-bottom: 0.4rem;
}

.blog-title {
  font-family: 'Rajdhani', sans-serif;
  font-size: 1rem;
  font-weight: 700;
  color: var(--white);
  margin-bottom: 0.4rem;
  line-height: 1.3;
}

.blog-excerpt {
  font-size: 12px;
  color: var(--text-light);
  line-height: 1.55;
  margin-bottom: 0.7rem;
}

.blog-date {
  font-size: 11px;
  color: var(--text-muted);
}

.section-cta { text-align: center; margin-top: 0.5rem; }

/* ─── CONTACT ─── */
.contact-section {
  background: var(--orange);
  padding: 4rem 3rem;
}

.contact-inner {
  max-width: 900px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 3rem;
}

.contact-section .section-title {
  color: var(--white);
  text-align: left;
  margin-bottom: 1.2rem;
}

.contact-info-item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 1.2rem;
}

.contact-icon {
  font-size: 1.4rem;
  margin-top: 2px;
  flex-shrink: 0;
}

.contact-label {
  font-family: 'Rajdhani', sans-serif;
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
  color: rgba(255,255,255,0.7);
  margin-bottom: 2px;
}

.contact-value {
  font-size: 14px;
  color: var(--white);
  line-height: 1.5;
}

.contact-form { display: flex; flex-direction: column; gap: 0.9rem; }

.form-input, .form-textarea {
  background: rgba(255,255,255,0.15);
  border: 1.5px solid rgba(255,255,255,0.35);
  border-radius: 4px;
  padding: 10px 14px;
  font-size: 13px;
  font-family: 'Open Sans', sans-serif;
  color: var(--white);
  outline: none;
  transition: border-color 0.2s;
}

.form-input::placeholder, .form-textarea::placeholder { color: rgba(255,255,255,0.55); }
.form-input:focus, .form-textarea:focus { border-color: var(--yellow); }

.form-textarea { resize: vertical; min-height: 100px; }

.btn-white {
  background: var(--white);
  color: var(--orange);
}
.btn-white:hover { background: var(--yellow); color: var(--green-dark); }

/* ─── FOOTER ─── */
.footer {
  background: #0f3a1c;
  padding: 3rem 3rem 1.5rem;
  border-top: 3px solid var(--orange);
}

.footer-grid {
  display: grid;
  grid-template-columns: 2fr 1fr 1fr 1fr;
  gap: 2.5rem;
  max-width: 900px;
  margin: 0 auto 2rem;
}

.footer-brand-text {
  font-size: 13px;
  color: var(--text-light);
  line-height: 1.7;
  margin-top: 0.8rem;
  max-width: 220px;
}

.footer-heading {
  font-family: 'Rajdhani', sans-serif;
  font-size: 14px;
  font-weight: 700;
  color: var(--yellow);
  text-transform: uppercase;
  letter-spacing: 0.06em;
  margin-bottom: 1rem;
}

.footer-links { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }

.footer-links a {
  font-size: 13px;
  color: var(--text-light);
  text-decoration: none;
  transition: color 0.2s;
}

.footer-links a:hover { color: var(--yellow); }

.footer-bottom {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding-top: 1.2rem;
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 900px;
  margin: 0 auto;
  font-size: 12px;
  color: var(--text-muted);
}

/* ─── MAP PLACEHOLDER ─── */
.map-placeholder {
  width: 100%;
  height: 300px;
  background: #1a5c2e;
  border-radius: 8px;
  overflow: hidden;
  position: relative;
  border: 1px solid rgba(255,255,255,0.15);
}

.map-inner {
  width: 100%; height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
  gap: 0.5rem;
  color: var(--text-muted);
}

/* ─── SCROLL REVEAL ─── */
.reveal {
  opacity: 0;
  transform: translateY(24px);
  transition: opacity 0.55s ease, transform 0.55s ease;
}
.reveal.visible {
  opacity: 1;
  transform: none;
}
</style>
</head>
<body>

<!-- NAV -->
<nav class="nav">
  <a class="logo" href="#">
    <div class="logo-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
        <circle cx="5" cy="17" r="4" stroke="#7ecb5a" stroke-width="1.8" fill="none"/>
        <circle cx="19" cy="17" r="4" stroke="#7ecb5a" stroke-width="1.8" fill="none"/>
        <path d="M5 17 L10 8 L15 8 L19 17" stroke="#7ecb5a" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        <path d="M10 8 L12 17" stroke="#7ecb5a" stroke-width="1.4" fill="none"/>
        <path d="M13 8 L15 4 L18 4" stroke="#7ecb5a" stroke-width="1.4" stroke-linecap="round" fill="none"/>
      </svg>
    </div>
    <div class="logo-text">Vélo<br><span>O CMC</span></div>
  </a>
  <ul class="nav-links">
    <li><a href="#accueil" class="nav-link active">Accueil</a></li>
    <li><a href="#histoire" class="nav-link">Notre Histoire</a></li>
    <li><a href="#circuits" class="nav-link">Nos Circuits</a></li>
    <li><a href="#blog" class="nav-link">Blog</a></li>
    <li><a href="#faq" class="nav-link">FAQ</a></li>
    <li><a href="#contact" class="nav-link">Contact</a></li>
  </ul>
</nav>

<!-- HERO -->
<section id="accueil" class="hero">
  <h1 class="hero-title">La liberté,<br>c'est sur deux roues !</h1>
  <p class="hero-sub">Balades urbaines ou grandes randonnées, nous avons le vélo et l'itinéraire qu'il vous faut. Laissez-vous guider et vivez Ribeauvillé comme jamais.</p>
  <a href="#circuits" class="btn">en savoir plus</a>

  <div class="search-row">
    <select class="search-select">
      <option value="">Destination ∨</option>
      <option>Ribeauvillé</option>
      <option>Route des Vins</option>
      <option>Forêt Noire</option>
      <option>Colmar</option>
    </select>
    <input type="date" class="search-input" style="min-width:130px;" />
    <select class="search-select">
      <option value="">Niveau ∨</option>
      <option>Débutant</option>
      <option>Intermédiaire</option>
      <option>Expert</option>
    </select>
    <button class="btn" style="padding:8px 20px;font-size:13px;">Explorer</button>
  </div>
</section>

<!-- ORANGE CHEVRON -->
<div class="chevron-orange"></div>

<!-- VÉLOS SECTION -->
<section class="section bikes-section">
  <h2 class="section-title">À chacun son vélo !</h2>
  <div class="bikes-grid">

    <!-- VAE -->
    <div class="bike-card reveal">
      <div class="diamond-wrap">
        <svg viewBox="0 0 120 120" xmlns="http://www.w3.org/2000/svg">
          <rect x="17" y="17" width="86" height="86" rx="4" fill="#f5c842" transform="rotate(45 60 60)"/>
          <svg x="22" y="40" width="76" height="40" viewBox="0 0 76 40">
            <circle cx="10" cy="30" r="9" stroke="#1a3a0a" stroke-width="2.5" fill="none"/>
            <circle cx="66" cy="30" r="9" stroke="#1a3a0a" stroke-width="2.5" fill="none"/>
            <path d="M10 30 L24 10 L42 10 L66 30" stroke="#1a3a0a" stroke-width="2.2" fill="none" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M24 10 L34 30" stroke="#1a3a0a" stroke-width="1.8" fill="none"/>
            <path d="M40 10 L44 4 L50 4" stroke="#1a3a0a" stroke-width="1.5" fill="none" stroke-linecap="round"/>
            <path d="M8 20 L12 20" stroke="#1a3a0a" stroke-width="2" stroke-linecap="round"/>
            <rect x="62" y="4" width="10" height="4" rx="2" fill="#1a3a0a"/>
            <circle cx="34" cy="22" r="5" stroke="#e07b00" stroke-width="2" fill="none"/>
            <circle cx="34" cy="22" r="2" fill="#e07b00"/>
          </svg>
        </svg>
      </div>
      <div class="bike-name">Vélo à assistance électrique</div>
      <p class="bike-desc">Pédaler plus facilement, ou plus loin, ou sans transpirer pour aller travailler. Le VAE réouvre l'usage du vélo à tous !</p>
    </div>

    <!-- BIPORTEUR -->
